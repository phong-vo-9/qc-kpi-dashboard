# ─── Jira connection (self-hosted Jira Server / Data Center) ───
JIRA_URL=https://jira.vexere.net

# Basic auth — enter YOUR OWN Jira login. Do NOT commit real values.
JIRA_USER=your.name@vexere.com
JIRA_PASS=your_password

# Optional: use a Personal Access Token instead of user+pass.
# If set, JIRA_TOKEN takes priority over JIRA_USER/JIRA_PASS.
# JIRA_TOKEN=

# ─── Data scope ───
JIRA_PROJECT=GOP
JIRA_QC_NAME=Nguyễn Phú Thành

# ─── Backend port ───
PORT=3001
