{
  "name": "qc-kpi-dashboard",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["server", "web"],
  "engines": {
    "node": ">=18.11"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev --workspace server\" \"npm run dev --workspace web\"",
    "start": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
